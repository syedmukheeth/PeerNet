# ─── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
CLIENT_URL=http://localhost:3000

# ─── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/peernet
# MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/peernet

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# REDIS_URL=redis://:password@host:6379

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_at_least_64_chars_long_random
JWT_REFRESH_SECRET=change_me_refresh_secret_at_least_64_chars_long_random
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5

# ─── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=logs

# ─── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Cookie ────────────────────────────────────────────────────────────────────
COOKIE_SECURE=false
